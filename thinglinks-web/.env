# 开发服务器端口。
VITE_PORT=3100

# 应用标题，用于浏览器标题和 Logo 文案。
VITE_GLOB_APP_TITLE=ThingLinks
# 应用简称，用于配置文件名称。
VITE_GLOB_APP_SHORT_NAME=thinglinks

# 菜单动态加载开关。
VITE_DYNAMIC_IMPORT=true

# 多租户数据隔离类型。
VITE_GLOB_MULTI_TENANT_TYPE=DATASOURCE_COLUMN

# 登录页验证码显示开关。
VITE_GLOB_SHOW_CAPTCHA=true

# OAuth 浏览器公共客户端兼容参数，与 Cloud def_client 记录一致。
# VITE_ 前缀变量会写入浏览器构建产物。
VITE_GLOB_CLIENT_SECRET=thinglinks_web_secret

# 后端运行模式，cloud 对应微服务，boot 对应单体。
VITE_GLOB_MODE=cloud

# 网站 Header 提示文案。
VITE_GLOB_TIPS="thinglinks · 开箱即用的 SaaS 物联网平台，快速接入 · 稳定连接 · 弹性扩展"

# 默认登录应用 ID，来源于 def_application 应用配置。
VITE_GLOB_DEF_APPLICATION_ID=1
# 基础平台应用 ID，来源于 def_application 应用配置。
VITE_GLOB_BASE_APPLICATION_ID=1
# 开发运营系统应用 ID，来源于 def_application 应用配置。
VITE_GLOB_DEV_OPERATION_APPLICATION_ID=2

# 第三方文件预览服务地址，服务类型为 kkFileView（https://gitee.com/kekingcn/file-online-preview）。
VITE_GLOB_PREVIEW_URL_PREFIX="http://127.0.0.1:8012/onlinePreview?url="

# 用户身份 Token 的请求头名称。
VITE_GLOB_TOKEN_KEY=Token

# 租户 ID 的请求头名称。
VITE_GLOB_TENANT_ID_KEY=TenantId

# 应用 ID 的请求头名称。
VITE_GLOB_APPLICATION_ID_KEY=ApplicationId

# 客户端认证信息的请求头名称。
VITE_GLOB_AUTHORIZATION_KEY=Authorization

# Axios 默认请求超时时间，单位为毫秒。
VITE_GLOB_AXIOS_TIMEOUT=30000

# Google Maps JavaScript API Key，用于演示地图加载。
VITE_GOOGLE_MAPS_API_KEY=
