# ThingLinks 产品元数据清单。
# scripts/product-config.sh 读取本文件并同步 Maven 坐标、版本和消息队列命名空间。
# 配置内容包括产品身份、组件版本、发行信息、授权信息、运行标识和同步边界。

# ==============================================================================
# 一、产品身份
# ==============================================================================
# 产品编码，用于跨组件关联 ThingLinks 产品。
THINGLINKS_PRODUCT_CODE=thinglinks
# 产品英文名称，用于文档和构建信息展示。
THINGLINKS_PRODUCT_NAME=ThingLinks
# 产品中文名称，用于中文文档和界面展示。
THINGLINKS_PRODUCT_NAME_ZH=ThingLinks物联网平台

# ==============================================================================
# 二、组件身份与版本
# ==============================================================================
# Cloud 组件编码，用于 Maven 坐标和组件识别。
THINGLINKS_COMPONENT_CODE=thinglinks-cloud
# Cloud 组件英文名称，用于构建信息和文档展示。
THINGLINKS_COMPONENT_NAME="ThingLinks Cloud"
# Cloud 组件发布版本，用于 Maven 版本和数据库增量脚本版本记录。
THINGLINKS_COMPONENT_VERSION=1.4.0
# ThingLinks Util 基础库依赖版本，用于 Cloud 公共依赖。
THINGLINKS_UTIL_VERSION=1.0.8.3
# Maven 根聚合工程 artifactId，用于 Cloud 聚合坐标。
THINGLINKS_MAVEN_ARTIFACT_ID=thinglinks-cloud

# ==============================================================================
# 三、发行信息
# ==============================================================================
# 发行类型编码，用于构建和同步工具识别发行信息。
THINGLINKS_EDITION_CODE=community
# 发行类型中文名称，用于中文授权和发行信息展示。
THINGLINKS_EDITION_NAME_ZH=社区版
# 发行类型英文名称，用于英文授权和发行信息展示。
THINGLINKS_EDITION_NAME_EN=Community

# ==============================================================================
# 四、授权信息
# ==============================================================================
# 授权模型编码，用于构建信息和发布物授权说明。
THINGLINKS_LICENSE_MODEL=open-source
# 授权文件路径，相对于 thinglinks-cloud 组件目录。
THINGLINKS_LICENSE_FILE=../LICENSE

# ==============================================================================
# 五、运行标识
# ==============================================================================
# 消息队列 Topic 与 Consumer Group 共用的命名空间。
THINGLINKS_MQ_NAMESPACE=thinglinks

# ==============================================================================
# 六、同步边界与清单格式
# ==============================================================================
# 产品清单格式版本，用于配置工具识别清单结构。
THINGLINKS_PRODUCT_MANIFEST_VERSION=1
# 跨发行同步时保留的产品清单和仓库授权文件路径，以英文逗号分隔。
THINGLINKS_SYNC_PROTECTED_PATHS=.thinglinks-product.env,../LICENSE,README.md,README.zh-CN.md,README.ja.md,README.ko.md,changelogs
# 发行标识扫描忽略的历史迁移说明与兼容脚本路径，以英文逗号分隔。
THINGLINKS_MARKER_SCAN_EXCLUDED_PATHS=changelogs/product-config-migration.md,docs/db/mysql/default/migration/README.md,docs/db/mysql/default/migration/V1.4.0__rename_web_oauth_client.sql
