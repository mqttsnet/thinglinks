# Nacos 配置中心命名空间
NACOS_NAMESPACE=replace-with-nacos-namespace
# Seata 分布式事务命名空间
SEATA_NAMESPACE=replace-with-seata-namespace
# Nacos 登录用户名
NACOS_USERNAME=replace-with-nacos-username
# Nacos 登录密码
NACOS_PASSWORD=replace-with-nacos-password
# AES 密钥，用于数据库敏感字段加密，长度为 16、24 或 32 字节
THINGLINKS_SECURITY_AES_KEY=replace-with-aes-key
# AES 初始化向量，用于 CBC 模式加解密，长度为 16 字节
THINGLINKS_SECURITY_AES_IV=replace-with-aes-iv
# 单个上传文件的容量上限
THINGLINKS_FILE_MAX_UPLOAD_SIZE=64MB
# 健康检查用户名
ACTUATOR_USERNAME=replace-with-actuator-username
# 健康检查密码
ACTUATOR_PASSWORD=replace-with-actuator-password
