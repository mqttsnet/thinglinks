# ThingLinks 产品元数据清单
# scripts/product-config.sh 读取本文件，用于校验产品元数据和渲染 Maven 兼容性版本。
# 内容包括产品、组件、发行、授权、兼容性与同步配置。

# ==============================================================================
# 一、产品身份
# ==============================================================================
# 产品编码；用于产品级标识和跨组件关联。
THINGLINKS_PRODUCT_CODE=thinglinks
# 产品英文展示名称；用于文档、构建信息和界面展示。
THINGLINKS_PRODUCT_NAME=ThingLinks
# 产品中文展示名称；用于中文文档和界面展示。
THINGLINKS_PRODUCT_NAME_ZH=ThingLinks物联网平台

# ==============================================================================
# 二、组件身份与版本
# ==============================================================================
# 当前仓库的组件编码；用于标识 BifroMQ 插件集合及 Maven 根聚合工程。
THINGLINKS_COMPONENT_CODE=bifromq-plugin
# 当前仓库的组件英文名称；用于构建信息和插件集合说明。
THINGLINKS_COMPONENT_NAME="BifroMQ Plugin"
# 插件集合发布版本；产品配置脚本将其写入根 POM 和四个插件父 POM。
THINGLINKS_COMPONENT_VERSION=1.4.0
# Maven 根聚合工程 artifactId；用于发布插件集合聚合坐标。
THINGLINKS_MAVEN_ARTIFACT_ID=bifromq-plugin
# Maven groupId；用于当前仓库模块与发布物坐标。
THINGLINKS_MAVEN_GROUP_ID=com.mqttsnet.thinglinks

# ==============================================================================
# 三、兼容性版本
# ==============================================================================
# BifroMQ SPI 兼容版本；用于四个插件父 POM 的依赖版本并对应 com.baidu.bifromq API。
THINGLINKS_BIFROMQ_VERSION=3.3.5
# 认证插件依赖的 ThingLinks Util 版本；用于认证插件父 POM 的基础库依赖。
THINGLINKS_UTIL_VERSION=1.0.8.1
# 插件编译目标 Java 主版本；产品配置脚本将其写入根 POM 和四个插件父 POM。
THINGLINKS_JAVA_VERSION=17

# ==============================================================================
# 四、发行版本
# ==============================================================================
# 发行版本机器编码；供构建、授权和同步工具识别发行类型。
THINGLINKS_EDITION_CODE=community
# 发行版本中文展示名称；用于中文文档和界面展示。
THINGLINKS_EDITION_NAME_ZH=社区版
# 发行版本英文展示名称；用于英文文档和界面展示。
THINGLINKS_EDITION_NAME_EN=Community

# ==============================================================================
# 五、授权信息
# ==============================================================================
# 授权模型编码；用于构建和发布物的授权说明。
THINGLINKS_LICENSE_MODEL=open-source
# 当前组件授权文件路径；用于发布物授权说明和同步保护路径。
THINGLINKS_LICENSE_FILE=LICENSE

# ==============================================================================
# 六、运行标识
# ==============================================================================
# 插件 Java 公共包名前缀；用于源码包路径和 standalone.yml 插件实现类名。
THINGLINKS_JAVA_PACKAGE_PREFIX=com.mqttsnet.thinglinks

# ==============================================================================
# 七、同步边界与清单格式
# ==============================================================================
# 清单格式版本；供解析脚本识别配置结构。
THINGLINKS_PRODUCT_MANIFEST_VERSION=1
# 同步保护路径列表；同步工具据此保留目标仓库文件，路径以英文逗号分隔。
THINGLINKS_SYNC_PROTECTED_PATHS=.thinglinks-product.env,LICENSE,LICENSE-COMMERCIAL,README.md,README.zh-CN.md,README.ja.md,README.ko.md
