# ThingLinks 产品元数据清单
# pnpm product:render 刷新派生文件；pnpm product:check 检查清单与工程状态。
# 内容类别：产品身份、组件版本、发行信息、授权信息、运行标识和仓库边界。

# ==============================================================================
# 一、产品身份
# ==============================================================================
# 产品编码，用于构建信息、接口标识和发行数据关联。
THINGLINKS_PRODUCT_CODE=thinglinks
# 产品英文展示名称，用于文档、构建信息和英文界面。
THINGLINKS_PRODUCT_NAME=ThingLinks
# 产品中文展示名称，用于中文文档和界面。
THINGLINKS_PRODUCT_NAME_ZH=ThingLinks物联网平台

# ==============================================================================
# 二、组件身份与版本
# ==============================================================================
# 大屏组件编码，用于构建信息和组件识别。
THINGLINKS_COMPONENT_CODE=thinglinks-web-visualize
# 大屏组件英文名称，用于构建信息和界面展示。
THINGLINKS_COMPONENT_NAME="ThingLinks Web Visualize"
# 大屏前端发布版本，用于 package.json、构建信息和界面版本展示。
THINGLINKS_COMPONENT_VERSION=1.4.0
# NPM 包名称，product:render 将其写入 package.json。
THINGLINKS_NPM_PACKAGE_NAME=thinglinks-web-visualize

# ==============================================================================
# 三、发行版本
# ==============================================================================
# 发行类型编码，用于构建信息和发行元数据选择。
THINGLINKS_EDITION_CODE=community
# 发行类型中文展示名称，用于中文界面。
THINGLINKS_EDITION_NAME_ZH=社区版
# 发行类型英文展示名称，用于英文界面。
THINGLINKS_EDITION_NAME_EN=Community
# 发行类型日文展示名称，用于日文界面。
THINGLINKS_EDITION_NAME_JA=コミュニティ版

# ==============================================================================
# 四、授权信息
# ==============================================================================
# 授权模型编码，用于构建信息和发布物授权说明。
THINGLINKS_LICENSE_MODEL=open-source
# 授权文件路径，用于构建检查和发布物授权说明。
THINGLINKS_LICENSE_FILE=LICENSE

# ==============================================================================
# 五、运行标识
# ==============================================================================
# 大屏 OAuth 客户端标识，来源于部署注册配置和 Cloud def_client 记录。
THINGLINKS_WEB_CLIENT_ID=thinglinks_view
# 消息队列 Topic 命名空间，用于跨前端组件保持统一的消息标识。
THINGLINKS_MQ_NAMESPACE=thinglinks
# 产品公共站点地址，用于界面中的示例链接和外部访问入口。
THINGLINKS_PUBLIC_SITE_URL=https://thinglinks.mqttsnet.com

# ==============================================================================
# 六、清单格式与仓库边界
# ==============================================================================
# 清单格式版本，用于解析器选择配置格式。
THINGLINKS_PRODUCT_MANIFEST_VERSION=1
# 仓库独立维护路径清单，用于产品配置与授权文件的边界识别。
THINGLINKS_SYNC_PROTECTED_PATHS=.thinglinks-product.env,LICENSE,README.md,README.zh-CN.md,README.ja.md,README.ko.md
