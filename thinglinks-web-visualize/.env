# Vite 开发服务端口。
VITE_DEV_PORT = '8080'

# 开发环境接口基础路径。
VITE_DEV_PATH = /api

# 生产环境接口基础路径。
VITE_PRODUCTION_PATH = /api

# 大屏应用运行端口。
VITE_PORT=3100

# 应用标题，用于浏览器标题和界面标识。
VITE_GLOB_APP_TITLE=ThingLinks_view
# 应用简称，用于本地缓存和配置文件命名。
VITE_GLOB_APP_SHORT_NAME=ThingLinks_view

# 菜单加载方式，true 表示从后台动态获取。
VITE_DYNAMIC_IMPORT=true

# 多租户数据隔离类型。
VITE_GLOB_MULTI_TENANT_TYPE=DATASOURCE_COLUMN

# 登录页验证码显示开关。
VITE_GLOB_SHOW_CAPTCHA=true

# OAuth 浏览器公共客户端兼容参数，与 Cloud def_client 记录一致。
VITE_GLOB_CLIENT_SECRET=thinglinks_view_secret

# 页面顶栏提示文字。
VITE_GLOB_TIPS=""

# 默认登录应用标识，对应 def_application 记录。
VITE_GLOB_DEF_APPLICATION_ID=1
# 基础平台应用标识，对应 def_application 记录。
VITE_GLOB_BASE_APPLICATION_ID=1
# 开发运营系统应用标识，对应 def_application 记录。
VITE_GLOB_DEV_OPERATION_APPLICATION_ID=2

# 第三方文件预览服务地址，默认适配 kkFileView。
VITE_GLOB_PREVIEW_URL_PREFIX="http://127.0.0.1:8012/onlinePreview?url="

# 用户身份令牌的请求头名称。
VITE_GLOB_TOKEN_KEY=Token

# 租户标识的请求头名称。
VITE_GLOB_TENANT_ID_KEY=TenantId

# 应用标识的请求头名称。
VITE_GLOB_APPLICATION_ID_KEY=ApplicationId

# OAuth 客户端认证信息的请求头名称。
VITE_GLOB_AUTHORIZATION_KEY=Authorization

# Axios 请求默认超时时间，单位为毫秒。
VITE_GLOB_AXIOS_TIMEOUT=10000
