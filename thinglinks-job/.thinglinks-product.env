# ThingLinks 产品元数据清单
# scripts/product-config.sh 读取本文件，用于校验和渲染 Job 的 Maven 与运行标识配置。
# 内容包括产品身份、组件版本、依赖版本、发行信息、授权信息、运行标识和同步边界。

# ==============================================================================
# 一、产品身份
# ==============================================================================
# 产品编码，用于产品级标识和跨组件关联。
THINGLINKS_PRODUCT_CODE=thinglinks
# 产品英文展示名称，用于文档和构建信息展示。
THINGLINKS_PRODUCT_NAME=ThingLinks
# 产品中文展示名称，用于中文文档和界面展示。
THINGLINKS_PRODUCT_NAME_ZH=ThingLinks物联网平台

# ==============================================================================
# 二、组件身份与版本
# ==============================================================================
# Job 组件编码，用于 Maven 坐标和组件识别。
THINGLINKS_COMPONENT_CODE=thinglinks-job
# Job 组件英文名称，用于构建信息和文档展示。
THINGLINKS_COMPONENT_NAME="ThingLinks Job"
# Job 组件发布版本，产品配置脚本将其写入根 POM 的 revision。
THINGLINKS_COMPONENT_VERSION=1.4.0
# Maven 根聚合工程 artifactId，用于 Job 聚合坐标和子模块父坐标。
THINGLINKS_MAVEN_ARTIFACT_ID=thinglinks-job
# Maven groupId，用于 Job 工程及其内部模块坐标。
THINGLINKS_MAVEN_GROUP_ID=com.mqttsnet.basic

# ==============================================================================
# 三、依赖与编译版本
# ==============================================================================
# ThingLinks Util 依赖版本，用于 thinglinks-parent 和 XXL-Job Core 依赖。
THINGLINKS_UTIL_VERSION=1.0.8.3
# Java 编译目标主版本，用于 Maven 编译参数。
THINGLINKS_JAVA_VERSION=17

# ==============================================================================
# 四、发行版本
# ==============================================================================
# 发行版本机器编码，用于构建、授权和同步工具识别发行类型。
THINGLINKS_EDITION_CODE=community
# 发行版本中文展示名称，用于中文授权和发行信息展示。
THINGLINKS_EDITION_NAME_ZH=社区版
# 发行版本英文展示名称，用于英文授权和发行信息展示。
THINGLINKS_EDITION_NAME_EN=Community

# ==============================================================================
# 五、授权信息
# ==============================================================================
# 授权模型编码，用于构建和发布物的授权说明。
THINGLINKS_LICENSE_MODEL=open-source
# 当前发行版本授权文件的仓库相对路径。
THINGLINKS_LICENSE_FILE=LICENSE

# ==============================================================================
# 六、运行标识
# ==============================================================================
# Job Admin 服务名称，用于 Spring 应用注册和服务发现。
THINGLINKS_SERVICE_NAME=thinglinks-job-admin

# ==============================================================================
# 七、同步边界与清单格式
# ==============================================================================
# 产品清单格式版本，用于产品配置脚本选择解析规则。
THINGLINKS_PRODUCT_MANIFEST_VERSION=1
# 跨发行版本同步保护路径列表，内容为英文逗号分隔的仓库相对路径。
THINGLINKS_SYNC_PROTECTED_PATHS=.thinglinks-product.env,LICENSE
